apiVersion: v1
kind: Secret
metadata:
  name: repl-runtime-secrets
  namespace: repls
type: Opaque
stringData:
  S3_BUCKET: "change-me"
  R2_ACCOUNT_ID: "change-me"
  REDIS_URL: "redis://redis.repls.svc.cluster.local:6379"
  AWS_ACCESS_KEY_ID: "change-me"
  AWS_SECRET_ACCESS_KEY: "change-me"
  JWT_SECRET: "change-me-must-be-32-chars-long!!"
