FROM deepanshumishra2004/execution_layer:latest

WORKDIR /app

RUN apt-get update \
  && apt-get install -y --no-install-recommends nodejs python3 make g++ \
  && rm -rf /var/lib/apt/lists/*

COPY ws-server/package.json ws-server/bun.lock ./ws-server/
RUN cd ws-server && bun install --frozen-lockfile

COPY ws-server ./ws-server
COPY main.sh ./

RUN chmod +x main.sh \
  && chmod 700 /app

EXPOSE 8080 3002

CMD ["bash", "main.sh"]
