FROM oven/bun:1

WORKDIR /app

RUN apt-get update \
  && apt-get install -y awscli python3 make g++ \
  && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /workspace \
  && useradd -m -s /bin/bash sandbox \
  && chown sandbox:sandbox /workspace

COPY /ws-server/package.json ./ws-server/
RUN cd ws-server && bun install

COPY /ws-server ./ws-server
COPY main.sh .

RUN chmod +x main.sh \
  && chmod 700 /app

EXPOSE 8080 3002

CMD ["bash", "main.sh"]